# FinBuddy Server — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# --- Database ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/finbuddy?retryWrites=true&w=majority

# --- Security ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<64-char-random-hex-string>
ENCRYPTION_KEY=<32-char-random-string>

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Client Origin ---
CLIENT_URL=http://localhost:5173

# --- Google OAuth ---
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# --- Cloudinary (for photo uploads) ---
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# --- Email (for OTP) ---
# Use a Gmail account with App Password enabled, or a SendGrid API key
EMAIL_USER=<your-email@gmail.com>
EMAIL_PASS=<your-gmail-app-password>

# --- AI (Groq) ---
GROQ_API_KEY=<your-groq-api-key>

# --- AI Fallback (Google Gemini) ---
GEMINI_API_KEY=<your-gemini-api-key>

# --- Razorpay (Payments) ---
# Use test keys for development, live keys only in production
RAZORPAY_KEY_ID=rzp_test_<your-key>
RAZORPAY_KEY_SECRET=<your-secret>
